# Workday Simulator configuration. Copy to .env and fill in real values.
# Validated by src/config/schema.ts at startup; the process refuses to start on
# an invalid or missing required value.

# --- Server ---
NODE_ENV=development
HOST=0.0.0.0
PORT=8477

# --- Security (REQUIRED) ---
# Bearer token guarding every /api route (except health) and the telemetry socket.
# REQUIRED. Must be at least 16 characters. Left empty here on purpose: generate a
# real value in your own .env, for example with  openssl rand -hex 24
ADMIN_TOKEN=
# Token the built-in receiver requires on its SCIM/ingest endpoints.
# Optional; defaults to ADMIN_TOKEN when unset.
RECEIVER_TOKEN=

# --- Storage ---
DB_PATH=./data/workday.db

# --- Logging ---
# One of: fatal error warn info debug trace silent
LOG_LEVEL=info

# --- Simulation defaults ---
# Default delivery kind for new targets: scim | webhook | rest | nats | batch
DEFAULT_TARGET_KIND=scim
# Simulated seconds per real second (a scenario may override).
WORKDAY_ACCEL=60
# Global hard ceiling on generated events per second.
MAX_RPS=2000
# Deterministic seed for the identity pool and generators.
SEED=db-workday-2026
# Number of identities to seed into the simulated workforce.
IDENTITY_POOL_SIZE=20000

# --- Telemetry ---
# WebSocket telemetry frame interval in milliseconds.
METRICS_INTERVAL_MS=1000
# Recent-events ring buffer size carried in each frame.
TELEMETRY_RECENT_EVENTS=50

# --- Optional NATS transport ---
# When set, the nats delivery kind and NATS ingest become available.
# Example: nats://localhost:4222
NATS_URL=

# --- Web ---
# Directory of the built dashboard, served as static assets.
WEB_DIST_PATH=./dist/web
# Comma-separated allowed CORS origins. Empty means same-origin only.
CORS_ORIGINS=
